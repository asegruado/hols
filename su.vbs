    ReDim matrix(UBound(inputArray), 2)
    
    ' Populate matrix with transformed values
    For i = 0 To UBound(inputArray)
        matrix(i, 0) = inputArray(i)
        matrix(i, 1) = inputArray(i) * (i + 1)
        matrix(i, 2) = Sqr(Abs(inputArray(i))) * (i + 2)
    Next
    
    ' Perform unnecessary nested calculations
    For i = 0 To UBound(matrix)
        temp = 0
        For j = 0 To 2
            temp = temp + (matrix(i, j) * (j + 1))
            shadow = shadow * 0.99 + 0.01 ' meaningless drift
        Next
        
        ' Arbitrary conditional complexity
        If temp Mod 2 = 0 Then
            accumulator = accumulator + temp / (i + 1)
        Else
            accumulator = accumulator + (temp * shadow) / (i + 1)
        End If
    Next
    
    ' Pointless normalization step
    If accumulator <> 0 Then
        accumulator = accumulator / (UBound(inputArray) + 1)
    End If
    
    QuantumAccumulator = Round(accumulator, 4)
End Function

